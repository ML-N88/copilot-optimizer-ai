{
  "name": "copilot-optimizer-ai",
  "displayName": "Copilot Optimizer AI",
  "description": "Get better Copilot answers automatically. Fix prompts. Improve answers. Learn over time.",
  "version": "1.1.0",
  "publisher": "morten-ln",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ML-N88/copilot-optimizer-ai"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Chat", "Other", "Programming Languages"],
  "keywords": ["copilot", "github copilot", "prompt", "optimizer", "LLM", "AI", "productivity"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/vscode/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "copilot-optimizer.chat",
        "name": "optimizer",
        "fullName": "Copilot Optimizer AI",
        "description": "Rewrites your prompt for accuracy, sends it to the model, and learns from the real response.",
        "isSticky": true,
        "commands": [
          { "name": "debug", "description": "Optimize as a debugging prompt" },
          { "name": "fix", "description": "Optimize as a fix prompt" },
          { "name": "refactor", "description": "Optimize as a refactor prompt" },
          { "name": "explain", "description": "Optimize as an explanation prompt" },
          { "name": "generate", "description": "Optimize as a code-generation prompt" },
          { "name": "raw", "description": "Bypass optimization \u2014 send your prompt unchanged (A/B compare)" },
          { "name": "dashboard", "description": "Open the optimizer dashboard" }
        ]
      }
    ],
    "configuration": {
      "title": "Copilot Optimizer AI",
      "properties": {
        "copilotOptimizer.tokenBudget": {
          "type": "number",
          "default": 400,
          "enum": [120, 250, 400, 800],
          "enumItemLabels": [
            "Max savings (120)",
            "Balanced (250)",
            "Accuracy-first (400)",
            "Maximum accuracy (800)"
          ],
          "enumDescriptions": [
            "Aggressive compression \u2014 smallest prompts, lowest token use.",
            "Moderate compression \u2014 a balance of savings and context.",
            "Light compression \u2014 keeps more context for better answers (recommended).",
            "Minimal compression \u2014 maximum context retained, highest token use."
          ],
          "markdownDescription": "Maximum tokens for the optimized prompt. **Lower** = more token savings (more aggressive compression). **Higher** = more accuracy (more context retained). Since the optimizer now talks to the model directly, an accuracy-first default is recommended."
        },
        "copilotOptimizer.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Master on/off switch for prompt optimization in the `@optimizer` chat participant. When off, prompts are passed through unchanged. Can also be toggled from the status bar."
        },
        "copilotOptimizer.contextFiles": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "maximum": 10,
          "markdownDescription": "How many of the top-ranked workspace files to read and attach (as real code, not just names) to the prompt sent to the model. Set to `0` to attach file names only."
        },
        "copilotOptimizer.contextCharBudget": {
          "type": "number",
          "default": 6000,
          "minimum": 0,
          "maximum": 40000,
          "markdownDescription": "Maximum total characters of attached file content sent to the model. Larger = more code context (more accurate) but more tokens used."
        },
        "copilotOptimizer.model": {
          "type": "string",
          "default": "",
          "enum": ["", "gpt-4o", "gpt-4o-mini", "o1", "o1-mini", "claude-3.5-sonnet", "gemini-1.5-pro"],
          "enumItemLabels": [
            "Chat default (recommended)",
            "GPT-4o",
            "GPT-4o mini",
            "o1",
            "o1-mini",
            "Claude 3.5 Sonnet",
            "Gemini 1.5 Pro"
          ],
          "enumDescriptions": [
            "Use whatever model is selected in the Copilot Chat dropdown.",
            "OpenAI GPT-4o.",
            "Smaller, faster GPT-4o.",
            "OpenAI o1 reasoning model.",
            "Smaller o1 reasoning model.",
            "Anthropic Claude 3.5 Sonnet.",
            "Google Gemini 1.5 Pro."
          ],
          "markdownDescription": "Preferred Copilot model family for `@optimizer` to send to. Choose **Chat default** to use the model picked in the chat dropdown. If the selected model isn't available to your account, the optimizer falls back automatically."
        }
      }
    },
    "commands": [
      {
        "command": "copilot-optimizer.optimize",
        "title": "Copilot Optimizer: Improve Prompt",
        "icon": "$(zap)"
      },
      {
        "command": "copilot-optimizer.quickSend",
        "title": "Copilot Optimizer: Quick Send (optimize & copy)",
        "icon": "$(send)"
      },
      {
        "command": "copilot-optimizer.toggleAutopilot",
        "title": "Copilot Optimizer: Toggle Autopilot"
      },
      {
        "command": "copilot-optimizer.showFeedback",
        "title": "Copilot Optimizer: Show Dashboard"
      },
      {
        "command": "copilot-optimizer.rebuildGraph",
        "title": "Copilot Optimizer: Rebuild Context Graph"
      },
      {
        "command": "copilot-optimizer.scoreResponse",
        "title": "Copilot Optimizer: Score Response"
      }
    ],
    "keybindings": [
      {
        "command": "copilot-optimizer.optimize",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "editorFocus"
      },
      {
        "command": "copilot-optimizer.quickSend",
        "key": "ctrl+alt+enter",
        "mac": "cmd+alt+enter",
        "when": "editorFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copilot-optimizer.quickSend",
          "group": "copilot",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "package": "vsce package --out copilot-optimizer-ai.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^18.0.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0"
  }
}
